# Normalize line endings: store as LF in the repo, check out native on each OS.
* text=auto

# Scripts that must keep specific endings
*.bat   text eol=crlf
*.cmd   text eol=crlf
gradlew text eol=lf
*.sh    text eol=lf

# Binary files — never touch line endings
*.jar   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
